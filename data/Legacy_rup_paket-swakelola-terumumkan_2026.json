    <style>*,
*::before,
*::after {
  box-sizing: border-box;
}
* {
  margin: 0;
}
body {
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}
img,
picture,
video,
canvas,
svg {
  display: block;
  max-width: 100%;
}
input,
button,
textarea,
select {
  font: inherit;
}
p,
h1,
h2,
h3,
h4,
h5,
h6 {
  overflow-wrap: break-word;
}

* {
  font-family: -apple-system, system-ui, BlinkMacSystemFont, Helvetica, Tahoma, sans-serif;
}

body {
  padding: 0 32px;
}

h1 {
  color: #d22b50;
  font-size: 40px;
  font-weight: 600;
}

a {
  color: #2f80ed;
  text-decoration: underline;
}

.label {
  display: inline-flex;
  justify-content: space-between;
  width: 100%;
  color: 4F4F4F;
}

.label::after {
  content: " : ";
  padding: 0 8px;
}

.value {
  font-weight: 600;
}

.button {
  text-decoration: none;
  background-color: #d22b50;
  padding: 12px;
  align-self: flex-start;
  color: #f2f2f2;
  font-weight: 600;
  border-radius: 8px;
}

h2 {
  margin-bottom: 12px;
}

table {
  border-collapse: separate;
  border-spacing: 0 12px;
}

.logo {
  margin-bottom: 80px;
}

.container {
  margin: auto;
  max-width: 320px;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  gap: 24px;
  padding: 32px 0; 
}

.message {
  max-width: 500px;
}

.cf-error-details h1 {
  font-size: 36px;
}

.cf-error-details p, .cferror_details {
  max-width: 500px;
}

@media (min-width: 640px) {
  .container {
    max-width: 640px;
    background: url(data:image/webp;base64,) no-repeat right;
  }
}

@media (min-width: 768px) {
  body {
    padding: 0 48px;
  }

  .container {
    max-width: 768px;
    padding: 48px 0;
  }

  h1 {
    font-size: 60px;
  }
}

@media (min-width: 1024px) {
  .container {
    max-width: 1024px;
  }

  body {
    padding: 0 128px;
  }
}

@media (min-width: 1280px) {
  .container {
    max-width: 1280px;
  }
}
</style>
